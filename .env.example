# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
TRUST_REVERSE_PROXY=False
SESSION_COOKIE_AGE=2592000
SESSION_EXPIRE_AT_BROWSER_CLOSE=False
SESSION_SAVE_EVERY_REQUEST=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURE_CROSS_ORIGIN_RESOURCE_POLICY=same-origin

# Database (Local SQLite default)
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL example:
# DATABASE_URL=postgresql://social_admin:change-this-postgres-password@localhost:5432/social_automation
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True

# Redis / Celery
REDIS_URL=redis://:change-this-redis-password@localhost:6379/0
CACHE_BACKEND=redis
CACHE_DEFAULT_TIMEOUT_SECONDS=300
CELERY_TIMEZONE=Asia/Kolkata
CELERY_PUBLISH_RATE_LIMIT=180/m
CELERY_INSIGHTS_REFRESH_RATE_LIMIT=90/m
CELERY_WORKER_MAX_TASKS_PER_CHILD=200
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_TIME_LIMIT=300
BULK_REFRESH_STALE_MINUTES=45
FORCE_REFRESH_IG_GUARD_MINUTES=20
FORCE_REFRESH_IG_GUARD_DUE_LIMIT=1
PUBLIC_BASE_URL=
DAILY_INSIGHTS_ENABLED=True
DAILY_INSIGHTS_SCHEDULE_HOUR=5
DAILY_INSIGHTS_SCHEDULE_MINUTE=0
DAILY_INSIGHTS_POST_LIMIT=100
DAILY_INSIGHTS_POST_STATS_LIMIT=40
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_TIMEOUT_SECONDS=90
MAX_UPLOAD_FILE_BYTES=104857600

# Meta
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET
META_REDIRECT_URI=http://localhost:8000/auth/meta/callback
META_GRAPH_VERSION=v21.0

# Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key
# Optional key rotation list (newest first)
# FERNET_KEYS=key1,key2

# Optional
# Example with ngrok:
# PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.dev
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password
POSTGRES_PASSWORD=change-this-postgres-password
REDIS_PASSWORD=change-this-redis-password
